import os
import sys
import menu_config
from SCons.Script import *

# 固定到插件内置的 lib/sim
PROJECT_ROOT = 'c:/wokspace/GitLoadHouse/honeygui-design/lib/sim'
TOOL_ROOT = os.path.join(PROJECT_ROOT, 'tool/scons-tool')

sys.path.append(TOOL_ROOT)
from building import *

TARGET = 'gui.exe' if sys.platform == 'win32' else 'gui'

# Windows: 使用内置 SDL2 静态库
sdl2_inc1 = 'c:/wokspace/GitLoadHouse/honeygui-design/lib/sim/SDL2-2.26.0-STATIC/include'
sdl2_inc2 = 'c:/wokspace/GitLoadHouse/honeygui-design/lib/sim/SDL2-2.26.0-STATIC/include/SDL2'
sdl2_libdir = 'c:/wokspace/GitLoadHouse/honeygui-design/lib/sim/SDL2-2.26.0-STATIC/lib'

# 构建环境参数
env_params = {
    'CC': menu_config.CC,
    'CFLAGS': menu_config.CFLAGS + ' -DDRV_LCD_WIDTH=800 -DDRV_LCD_HEIGHT=480 -DDRV_LCD_CORNER_RADIUS=20 -Ic:/wokspace/GitLoadHouse/honeygui-design/lib/sim/include -I' + sdl2_inc1 + ' -I' + sdl2_inc2,
    'CXX': menu_config.CXX,
    'CXXFLAGS': menu_config.CXXFLAGS,
    'LINKFLAGS': menu_config.LFLAGS
}

if sys.platform == 'win32':
    env = Environment(tools=['mingw'], **env_params)
    env['LINK'] = 'g++'
    env['SHLINK'] = 'g++'
else:
    env = Environment(tools=['default'], PROGSUFFIX='', **env_params)
    env['LINK'] = 'g++'

# PC 仿真宏
env.Append(CPPDEFINES=['_HONEYGUI_SIMULATOR_'])

# 头文件与库路径
env.AppendUnique(CPPPATH=['c:/wokspace/GitLoadHouse/honeygui-design/lib/sim/include', sdl2_inc1, sdl2_inc2])
env.AppendUnique(LIBPATH=['c:/wokspace/GitLoadHouse/honeygui-design/lib/sim/win32', sdl2_libdir])

# 系统库
env.AppendUnique(LIBS=['mingw32', 'gui', 'SDL2main', 'SDL2', 'opengl32', 'gdi32', 'user32', 'winmm', 'imm32', 'ole32', 'oleaut32', 'version', 'uuid', 'advapi32', 'setupapi', 'shell32', 'dinput8', 'm'])

# 准备环境（会自动编译当前目录的 SConscript）
objs = PrepareBuilding(env, TOOL_ROOT, has_libcpu=False)

# 编译项目代码
PROJECT_SRC = 'c:/wokspace/GitLoadHouse/honeygui-design/template-projects/dashboard/src'
if os.path.exists(os.path.join(PROJECT_SRC, 'SConscript')):
    objs.extend(SConscript(os.path.join(PROJECT_SRC, 'SConscript')))

DoBuilding(TARGET, objs)
